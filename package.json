{
  "name": "personnal-website",
  "version": "1.0.0",
  "private": false,
  "repository": "git@github.com:remipassmoilesel/personnal-website.git",
  "license": "GPL-3.0",
  "author": "Rémi Passmoilesel <r.passmoilesel@protonmail.com>",
  "scripts": {
    "start": "DEBUG=true parcel src/index.html",
    "watch": "tsc --noEmit -w",
    "format": "npm-run-all format:*",
    "format:code": "eslint --fix './src/**/{*.tsx,*.ts}' --max-warnings=0 && pprettier --write 'src/**/*.scss'",
    "format:packagejson": "sort-package-json",
    "build": "npm-run-all build:frontend build:pdf:*",
    "build:frontend": "tsc --noEmit && parcel build src/index.html",
    "build:pdf:en": "pandoc --defaults pandoc-en.yaml",
    "build:pdf:fr": "pandoc --defaults pandoc-fr.yaml"
  },
  "dependencies": {
    "clsx": "^1.2.1",
    "i18next": "^22.0.5",
    "i18next-browser-languagedetector": "^7.0.1",
    "lodash": "^4.17.21",
    "loglevel": "^1.8.1",
    "normalize.css": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-emoji-render": "^1.2.4",
    "react-i18next": "^12.0.0",
    "react-markdown": "^8.0.3",
    "typed.js": "^2.0.12",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@mixer/parallel-prettier": "^2.0.3",
    "@parcel/transformer-html": "^2.8.0",
    "@parcel/transformer-inline-string": "^2.8.0",
    "@parcel/transformer-sass": "^2.8.0",
    "@types/lodash": "^4.14.188",
    "@types/node": "^18.11.9",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.8",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.42.1",
    "eslint": "^8.27.0",
    "eslint-config-standard-with-typescript": "^23.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.5.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.31.10",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.8.0",
    "prettier": "^2.7.1",
    "process": "^0.11.10",
    "sass": "^1.56.1",
    "sort-package-json": "^2.1.0",
    "typescript": "^4.8.4"
  },
  "volta": {
    "node": "18.12.1"
  }
}
